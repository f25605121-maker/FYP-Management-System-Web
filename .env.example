# ╔════════════════════════════════════════════════════════════════╗
# ║  FYP Management System - Environment Configuration               ║
# ║  Copy this to .env and fill in your values before deployment     ║
# ╚════════════════════════════════════════════════════════════════╝

# ──────────────────────────────────────────────────────────────────
# FLASK CORE CONFIGURATION
# ──────────────────────────────────────────────────────────────────

FLASK_ENV=production
# Generate SECRET_KEY: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your-secret-key-here-min-32-characters
DEBUG=False

# ──────────────────────────────────────────────────────────────────
# SERVER CONFIGURATION
# ──────────────────────────────────────────────────────────────────

PORT=5000
# For production, comma-separated allowed domains (Railway will auto-fill)
ALLOWED_ORIGINS=https://your-app.up.railway.app,https://your-domain.com

# ──────────────────────────────────────────────────────────────────
# DATABASE CONFIGURATION
# ──────────────────────────────────────────────────────────────────

# PRODUCTION: Use PostgreSQL (Railway provides this automatically)
# Format: postgresql://user:password@host:port/database
DATABASE_URL=postgresql://postgres:password@localhost:5432/fyp_db

# DEVELOPMENT ONLY: Local SQLite database
# DATABASE_URL=sqlite:///./fyp.db

# ──────────────────────────────────────────────────────────────────
# EMAIL CONFIGURATION (Required for password reset features)
# ──────────────────────────────────────────────────────────────────

MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=True
MAIL_USERNAME=your-email@gmail.com
# For Gmail: Use App Password (not regular password)
# See: https://support.google.com/accounts/answer/185833
MAIL_PASSWORD=your-app-specific-password
MAIL_DEFAULT_SENDER=noreply@fyp-system.com

# ──────────────────────────────────────────────────────────────────
# GOOGLE OAUTH (Optional but Recommended)
# ──────────────────────────────────────────────────────────────────

# Get these from: https://console.cloud.google.com/
# Steps:
#   1. Create new project in Google Cloud Console
#   2. APIs & Services > Credentials
#   3. Create OAuth 2.0 Client ID (Web application)
#   4. Add these Authorized redirect URIs:
#      - http://localhost:5000/authorize (dev)
#      - https://your-app.up.railway.app/authorize (production)

GOOGLE_CLIENT_ID=your-client-id-from-google-console
GOOGLE_CLIENT_SECRET=your-client-secret-from-google-console

# ──────────────────────────────────────────────────────────────────
# ADMIN ACCOUNT (Set on first deployment)
# ──────────────────────────────────────────────────────────────────

ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-this-to-strong-password-in-production

# ──────────────────────────────────────────────────────────────────
# FILE UPLOAD CONFIGURATION
# ──────────────────────────────────────────────────────────────────

MAX_UPLOAD_SIZE=16777216  # 16MB in bytes
UPLOAD_FOLDER=/tmp/uploads

# ──────────────────────────────────────────────────────────────────
# LOGGING & MONITORING
# ──────────────────────────────────────────────────────────────────

LOG_LEVEL=INFO
# DEBUG, INFO, WARNING, ERROR, CRITICAL

# ──────────────────────────────────────────────────────────────────
# RAILWAY-SPECIFIC (Auto-set by Railway, don't modify)
# ──────────────────────────────────────────────────────────────────

# RAILWAY_ENVIRONMENT_NAME=production
# RAILWAY_ENVIRONMENT_ID=
# RAILWAY_PUBLIC_DOMAIN=your-app.up.railway.app
